											"name": "Playername",
											"type": "String",
											"value": "Dhoni",
											"direction": "Input"
										}
									],
									"type": "Query",
									"text": "select * from [dbo].[iplteams] where name =@Playername"
								},
								{
									"type": "NonQuery",
									"text": "update [dbo].[iplteams] set score=1000 where name='Rohit'"
								}
							],
							"scriptBlockExecutionTimeout": "02:00:00"
						}
					}
				],
