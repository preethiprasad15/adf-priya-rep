											"type": "Expression"
										}
									}
								}
							],
							"outputs": [
								{
									"referenceName": "Json1",
									"type": "DatasetReference",
									"parameters": {
										"foldername": {
											"value": "@concat('target/',item().name,'/dt=',formatDateTime(utcNow(),'yyyyMMdd'))",
											"type": "Expression"
										},
										"filename": {
											"value": "@concat(item().name,'.json')",
											"type": "Expression"
										}
									}
								}
							]
						}
					]
				}
			}
		],
		"parameters": {
			"pTableList": {
				"type": "array",
				"defaultValue": [
					{
						"name": "products",
						"relativeUrl": "/products"
					},
					{
						"name": "users",
						"relativeUrl": "/users"
					},
					{
						"name": "comments",
						"relativeUrl": "/comments"
					}
				]
			}
		},
		"variables": {
